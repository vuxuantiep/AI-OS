*.log
*.tmp
*.temp
.DS_Store
Thumbs.db

# Node.js / Python (falls du Tools installierst)
node_modules/
.wrangler/
__pycache__/
*.pyc
.Python
env/
venv/
.venv/

# Backup-Dateien
*.bak
*.backup
*~
*.swp
*.swo

# Große Dateien
*.zip
*.tar.gz
*.mp4
*.mp3
*.mov

# Private Notizen (falls du private Dinge nicht teilen willst)
00_Wissen/01_Persönlich/Personal/Private/

# Claude-spezifisch (falls nötig)
.claude/
