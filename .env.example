# AI-OS Umgebungsvariablen — Vorlage
# Kopieren nach .env (wird NICHT versioniert, siehe .gitignore).
# Alle echten Keys gehören in die .env — nie in versionierte Dateien.

# Cal.ai Agent (Port 5301)
CAL_API_KEY=your_cal_api_key_here
CAL_USERNAME=your_cal_username

# Bubble.io Agent (Port 5302)
BUBBLE_API_TOKEN=your_bubble_token_here
BUBBLE_APP_NAME=your_bubble_app_name

# Higgsfield Agent (Port 5303)
HIGGSFIELD_API_KEY=your_higgsfield_api_key_here

# LLM-Modell für die Spezial-Agenten (Default: llama3; Alternativen: mistral, qwen2.5-coder, gemma4)
AGENT_LLM_MODEL=llama3

# === LLM-Router: lokale Engines & Fallbacks (Ollama lokal braucht keinen Key) ===
# Autostart der lokalen Engine (Ollama/LM Studio) beim Dashboard-Start: 1 = an (Default), 0 = aus
AI_OS_LLM_AUTOSTART=1

# Raspberry Pi 4 Gateway (miniLLM im LAN): Ollama- ODER OpenAI-kompatibler Endpunkt
# z.B. http://raspberrypi.local:11434 (Ollama) oder http://192.168.1.50:8080 (llama.cpp)
PI_LLM_URL=
# Optional: festes Modell auf dem Pi (leer = automatisch erkennen)
PI_LLM_MODEL=
# Optional: API-Key, falls das Pi-Gateway einen verlangt
PI_LLM_API_KEY=

# GitHub Models (nutzt dein GitHub/Copilot-Konto): PAT unter
# https://github.com/settings/tokens mit Berechtigung "models:read" erstellen
GITHUB_MODELS_TOKEN=

# === LLM-Router: Online-Fallback ===
# Kostenlos erstellen: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=
# huggingface.co -> Settings -> Access Tokens, Berechtigung "Make calls to Inference Providers"
HUGGINGFACE_API_KEY=
# Cloudflare Dashboard -> Workers & Pages -> Account-ID.
# Achtung: bewusst NICHT CLOUDFLARE_ACCOUNT_ID/CLOUDFLARE_API_TOKEN nennen —
# diese Namen liest wrangler mit und Deploys schlagen dann fehl.
WORKERS_AI_ACCOUNT_ID=
# https://dash.cloudflare.com/profile/api-tokens, Vorlage "Workers AI"
WORKERS_AI_API_TOKEN=
# Optional: Name deines Cloudflare AI Gateway (leer = direkter Workers-AI-Zugriff)
WORKERS_AI_GATEWAY=
