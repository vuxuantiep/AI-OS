{
  "manifest_version": 3,
  "name": "Broki Ai - lokaler Wiki Assistent",
  "version": "0.1.0",
  "description": "Firmen-Wiki + KI-Berater, 100 % lokal im Browser. Sync über Tailscale vom Raspberry Pi, dreistufiges Gedächtnis, IT-Crash-Rollback.",
  "minimum_chrome_version": "121",

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "action": {
    "default_title": "Broki AI öffnen",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["https://*.firmen-domain.example/*"],
      "js": ["content/content-script.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms",
    "sidePanel",
    "scripting",
    "offscreen"
  ],

  "host_permissions": [
    "http://pi-ki-tiep.tailed32d1.ts.net:8088/*",
    "http://127.0.0.1:11434/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
